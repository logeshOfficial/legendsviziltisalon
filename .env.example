# Sanity CMS (optional — demo works without these)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity write token — used by the /admin CMS panel (keep secret, never commit)
# Create one at sanity.io/manage → your project → API → Tokens → Add token (Editor role)
NEXT_PUBLIC_SANITY_WRITE_TOKEN=

# Admin panel credentials — protect the /admin page
NEXT_PUBLIC_ADMIN_USERNAME=admin
NEXT_PUBLIC_ADMIN_PASSWORD=

# GitHub Personal Access Token to trigger site rebuild from admin panel
# Create at github.com/settings/tokens → Fine-grained or Classic with "workflow" scope
NEXT_PUBLIC_GITHUB_DEPLOY_TOKEN=ghp_...

# Contact form (optional — Formspree)
NEXT_PUBLIC_FORMSPREE_ID=
